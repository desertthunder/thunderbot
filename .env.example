# Bluesky Configuration
TNBOT_BLUESKY__HANDLE=your-handle.bsky.social
TNBOT_BLUESKY__APP_PASSWORD=your-app-password
TNBOT_BLUESKY__PDS_HOST=https://bsky.social

# Bot Configuration
TNBOT_BOT__DID=did:plc:your-bot-did
TNBOT_BOT__NAME=ThunderBot

# Access Control (optional)
# TNBOT_ACCESS__ALLOWED_DIDS=did:plc:friend1,did:plc:friend2
# TNBOT_ACCESS__ALLOWED_HANDLES=alice.bsky.social,bob.bsky.social
# TNBOT_ACCESS__UNAUTHORIZED_POLICY=store_no_reply

# Database Configuration
TNBOT_DATABASE__PATH=./data/thunderbot.db

# Logging Configuration
TNBOT_LOGGING__LEVEL=info
TNBOT_LOGGING__FORMAT=pretty

# Web Operator Login (optional)
# TNBOT_WEB__USERNAME=admin
# TNBOT_WEB__PASSWORD=change-me

# GLM-5 API Key
# GLM_5_API_KEY=your-api-key
