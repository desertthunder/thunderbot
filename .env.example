# Bluesky Configuration
TNBOT_BLUESKY__HANDLE=bot-handle.bsky.social
TNBOT_BLUESKY__APP_PASSWORD=bot-app-password
# Optional override (auto-resolved from Bluesky API by default)
# TNBOT_BLUESKY__PDS_HOST=https://bsky.social

# Bot Identity Overrides (auto-resolved from Bluesky API by default)
# TNBOT_BOT__DID=did:plc:bot-account-did
# TNBOT_BOT__NAME=ThunderBot

# Access Control (optional)
# TNBOT_ACCESS__ALLOWED_DIDS=did:plc:friend1,did:plc:friend2
# TNBOT_ACCESS__ALLOWED_HANDLES=alice.bsky.social,bob.bsky.social
# TNBOT_ACCESS__UNAUTHORIZED_POLICY=store_no_reply

# Database Configuration (optional override)
# Default is OS app data:
#   Linux/macOS: ~/.local/share/thunderbot/thunderbot.db
#   Windows: %APPDATA%\thunderbot\thunderbot.db
# TNBOT_DATABASE__PATH=./data/thunderbot.db

# Logging Configuration
TNBOT_LOGGING__LEVEL=info
TNBOT_LOGGING__FORMAT=pretty

# Web Operator Login (optional)
# TNBOT_WEB__USERNAME=admin
# TNBOT_WEB__PASSWORD=change-me

# GLM-5 API Key
# GLM_5_API_KEY=ai-provider-api-key
